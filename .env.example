# =============================================================================
# Principal's Portfolio — Environment Variables
# =============================================================================
# 
# HOW TO SET UP:
# 1. Create a Google Sheet with 13 tabs (Profile, About, Education, etc.)
# 2. Share the sheet as "Anyone with the link can view"
# 3. Copy the Spreadsheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]/edit
# 4. For each tab, get the GID from the URL when that tab is active:
#    https://docs.google.com/spreadsheets/d/.../edit#gid=[THIS_IS_THE_GID]
# 5. Fill in the values below
# =============================================================================

NEXT_PUBLIC_GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Sheet tab GIDs (found in URL when each tab is active)
# The first tab is always gid=0
NEXT_PUBLIC_GID_PROFILE=0
NEXT_PUBLIC_GID_ABOUT_ME=
NEXT_PUBLIC_GID_QUALIFICATION=
NEXT_PUBLIC_GID_EXPERIENCE=
NEXT_PUBLIC_GID_RESEARCH_PROJECT=
NEXT_PUBLIC_GID_CONSULTANCY=
NEXT_PUBLIC_GID_PUBLICATIONS=
NEXT_PUBLIC_GID_AWARDS_ACHIEVEMENTS=
NEXT_PUBLIC_GID_PAPER_PRESENTATIONS=
NEXT_PUBLIC_GID_RESEARCH_INTERESTS=
NEXT_PUBLIC_GID_GALLERY=
NEXT_PUBLIC_GID_INTERNATIONAL_EXPOSURE=
NEXT_PUBLIC_GID_REVIEWER=

# Site URL (for SEO)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
